---
import { siteConfig } from '@/config/site';
---

<footer class="border-t border-puerto-steel/40 bg-puerto-deep">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-6 py-8 sm:flex-row">
    <a href="/" aria-label="Puerto home">
      <img
        src={siteConfig.logo.src}
        alt={siteConfig.logo.alt}
        width={80}
        height={18}
        class="h-5 w-auto opacity-70 transition-opacity hover:opacity-100"
      />
    </a>

    <nav class="flex items-center gap-6" aria-label="Footer navigation">
      <a href="/docs" class="font-sans text-sm text-puerto-mist transition-colors hover:text-puerto-ice">Docs</a>
      <a href={siteConfig.github} target="_blank" rel="noopener noreferrer" class="font-sans text-sm text-puerto-mist transition-colors hover:text-puerto-ice">GitHub</a>
      <a href="https://github.com/Guuri11/Puerto/blob/main/LICENSE" target="_blank" rel="noopener noreferrer" class="font-sans text-sm text-puerto-mist transition-colors hover:text-puerto-ice">MIT License</a>
    </nav>

    <p class="font-sans text-xs text-puerto-mist/60">
      Built with Puerto · {new Date().getFullYear()}
    </p>
  </div>
</footer>
